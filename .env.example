# Auth0 (Next.js SDK v4) — see ARCHITECTURE.md and BUGLOG.md
# Generate AUTH0_SECRET: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://anzen.api
APP_BASE_URL=http://localhost:3000

# Set to true only after completing Token Vault setup (see ARCHITECTURE.md)
# Leave false or unset for basic sign-in while configuring Auth0.
AUTH0_TOKEN_VAULT_SCOPES=false

# Optional — for scripts/configure-auth0-connections.mjs (Management API, machine-to-machine)
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=

# AI agent
GROQ_API_KEY=

# Optional — used by some client-side links
NEXT_PUBLIC_APP_URL=http://localhost:3000
